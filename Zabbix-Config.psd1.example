@{
    # Netzwerk / Server
    ZabbixServer = "192.168.1.100"  # IP/Hostname deines Zabbix Servers
    MsiPath = "\\server\share\zabbix_agent.msi"  # UNC-Pfad zur MSI-Datei

    # Zabbix API
    ZabbixApiUser = "Admin"  # Zabbix Admin Benutzername
    ZabbixApiPassword = "zabbix"  # Zabbix API Passwort

    # Domain / Remote Admin
    Domain = "DEINEDOMAIN"  # Windows Domain Name
    DomainAdminUser = "admin.benutzer"  # Domain Admin Benutzername
    DomainPassword = ""  # Domain-Passwort (leer lassen für Abfrage beim Start)
}
